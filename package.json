{
    "name": "mini-mealie",
    "description": "manifest.json description",
    "private": true,
    "type": "module",
    "scripts": {
        "predev": "node scripts/check-dev-env.js",
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "compile": "tsc --noEmit",
        "postinstall": "wxt prepare && git config core.hooksPath .githooks && chmod +x .githooks/* ",
        "test": "vitest",
        "lint": "eslint",
        "lint-compact": "eslint -f compact",
        "coverage": "vitest run --coverage",
        "vitest-ui": "vitest run --ui",
        "html-coverage": "pnpm vitest --ui --coverage.enabled=true",
        "commitlint": "commitlint --edit"
    },
    "dependencies": {
        "@react-email/components": "^1.0.12",
        "normalize-url": "^9.0.0",
        "react": "^19.2.6",
        "react-dom": "^19.2.5",
        "resend": "^4.8.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@eslint/css": "^1.2.0",
        "@eslint/js": "^9.39.4",
        "@html-eslint/parser": "^0.60.0",
        "@semantic-release/git": "^10.0.1",
        "@types/chrome": "^0.1.42",
        "@types/eslint-plugin-security": "^3.0.1",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/ui": "^3.2.4",
        "@wxt-dev/module-react": "^1.2.2",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-formatter-compact": "^9.0.1",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-simple-import-sort": "^12.1.1",
        "globals": "^16.5.0",
        "prettier": "^3.8.3",
        "semantic-release": "^24.2.9",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.2",
        "vitest": "^3.2.4",
        "wxt": "^0.20.26"
    },
    "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
    "pnpm": {}
}
