{
    "name": "mini-mealie",
    "description": "manifest.json description",
    "private": true,
    "type": "module",
    "scripts": {
        "predev": "node scripts/check-dev-env.js",
        "dev": "wxt",
        "dev:firefox": "wxt -b firefox",
        "build": "wxt build",
        "build:firefox": "wxt build -b firefox",
        "zip": "wxt zip",
        "zip:firefox": "wxt zip -b firefox",
        "typecheck": "tsc --noEmit",
        "typecheck:e2e": "tsc --noEmit -p tsconfig.e2e.json",
        "postinstall": "wxt prepare && git config core.hooksPath .githooks && chmod +x .githooks/* ",
        "test": "vitest",
        "lint": "eslint",
        "lint-compact": "eslint -f compact",
        "coverage": "vitest run --coverage",
        "vitest-ui": "vitest run --ui",
        "html-coverage": "pnpm vitest --ui --coverage.enabled=true",
        "commitlint": "commitlint --edit",
        "test:e2e:up": "tsx e2e-shared/mealie-docker.ts up",
        "test:e2e:down": "tsx e2e-shared/mealie-docker.ts down",
        "test:e2e:chromium:install": "playwright install chromium",
        "test:e2e:chromium": "playwright test --config=e2e-playwright/playwright.config.ts",
        "test:e2e:gecko:setup": "bash e2e-geckodriver/setup.sh",
        "test:e2e:gecko": "cross-env WXT_E2E=true pnpm zip:firefox && tsx e2e-geckodriver/firefox-e2e.ts",
        "test:e2e": "pnpm test:e2e:up && cross-env WXT_E2E=true pnpm build && (pnpm test:e2e:chromium; ec=$?; pnpm test:e2e:down; exit $ec)"
    },
    "dependencies": {
        "normalize-url": "^9.0.1",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "resend": "^6.17.1"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.2.0",
        "@commitlint/config-conventional": "^21.2.0",
        "@eslint/css": "^1.4.0",
        "@eslint/js": "^10.0.1",
        "@html-eslint/parser": "^0.63.0",
        "@playwright/test": "^1.59.0",
        "@semantic-release/git": "^10.0.1",
        "@types/chrome": "^0.2.1",
        "@types/eslint-plugin-security": "^3.0.1",
        "@types/filesystem": "^0.0.36",
        "@types/har-format": "^1.2.16",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.15",
        "@types/react-dom": "^19.2.3",
        "@types/selenium-webdriver": "^4.1.28",
        "@vitest/coverage-v8": "^4.1.10",
        "@vitest/ui": "^4.1.10",
        "@wxt-dev/module-react": "^1.2.2",
        "cross-env": "^10.1.0",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-formatter-compact": "^9.0.1",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "github:ledsun/eslint-plugin-react#update-deprecated-calls-v8",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-simple-import-sort": "^13.0.0",
        "globals": "^17.7.0",
        "playwright": "^1.59.0",
        "prettier": "^3.9.4",
        "selenium-webdriver": "^4.30.0",
        "semantic-release": "^25.0.5",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.63.0",
        "vitest": "^4.1.10",
        "wxt": "^0.20.27"
    },
    "packageManager": "pnpm@11.2.2"
}
